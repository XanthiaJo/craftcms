{% extends '_layouts/base.twig' %}

{% block pageTitle %}
    {{ category.title }} - {{ parent() }}
{% endblock %}

{% block pageDescription %}
    Posts tagged in the {{ category.title }} category.
{% endblock %}

{% block pageSubheader %}
    {% include '_partials/page-subheader.twig' with { pageName: category.title } %}
{% endblock %}

{% block pageContent %}
<main class="projects">
    <div class="shell">
        {% set entries = craft.entries.section('posts').type('post').relatedTo(category).orderBy('postDate desc').all() %}
        <div class="grid" aria-label="{{ category.title }} posts">
            {% for entry in entries %}
                {% set image = entry.featuredImage ? entry.featuredImage.one() : null %}
                <article class="panel panel--image-top">
                    {% if image %}
                        <img class="thumb" src="{{ image.url }}" alt="{{ image.title ?: entry.title }}">
                    {% endif %}
                    <div class="panel-body">
                        <h3><a href="{{ entry.url }}">{{ entry.title }}</a></h3>
                        {% if entry.body %}
                            <div>{{ entry.body|striptags|trim|slice(0, 145) ~ '...' }}</div>
                        {% endif %}
                    </div>
                </article>
            {% else %}
                <article class="panel panel--padded">
                    <h3>No posts in this category yet</h3>
                    <div>Check back after more posts are tagged.</div>
                </article>
            {% endfor %}
        </div>
    </div>
</main>
{% endblock %}