{% extends '_layouts/base.twig' %}

{% block pageTitle %}
    CSS Style Guide - {{ parent() }}
{% endblock %}

{% block pageDescription %}
    Visual reference for the site's generic element styles and shared classes.
{% endblock %}

{% block pageSubheader %}
    {% include '_partials/page-subheader.twig' with { pageName: 'CSS Style Guide' } %}
{% endblock %}

{% block headExtra %}
    <style>
        .example-group {
            margin-bottom: 24px;
        }
        .example-label {
            font-family: monospace;
            background: var(--secondary-light);
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            margin-bottom: 8px;
            display: inline-block;
            white-space: nowrap;
        }
        .color-swatch {
            display: inline-block;
            width: 60px;
            height: 40px;
            border: 1px solid var(--border);
            border-radius: 4px;
            margin-right: 12px;
            vertical-align: middle;
        }
        .color-info {
            display: inline-block;
            vertical-align: middle;
        }

        .example-row {
            display: flex;
            flex-wrap: wrap;
            gap: 24px;
            align-items: flex-start;
        }

        .example-row > .example-group {
            flex: 1 1 220px;
            min-width: 0;
            display: flex;
            flex-direction: column;
        }

        /* Accordion sections */
        details.panel {
            padding: 0;
        }
        details.panel > summary {
            padding: 16px 24px;
            cursor: pointer;
            list-style: none;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            border-bottom: 0;
            transition: border-color 0.15s;
        }
        details.panel > summary::-webkit-details-marker {
            display: none;
        }
        details.panel > summary > h2 {
            margin: 0;
        }
        details.panel > summary::after {
            content: '\25B8';
            font-size: 14px;
            color: var(--body-light);
            transition: transform 0.15s;
        }
        details.panel[open] > summary {
            border-bottom: 1px solid var(--border);
        }
        details.panel[open] > summary::after {
            transform: rotate(90deg);
        }
        details.panel > .panel--padded__body,
        details.panel > p {
            padding: 24px;
        }
        details.panel > p {
            margin: 0;
            padding-bottom: 0;
        }
    </style>
{% endblock %}

{% block pageContent %}
<main class="page-main">
    <div class="shell page-layout">
        <div class="content-main">
            <div class="container">

                <!-- Typography -->
                <details class="panel panel--padded" id="typography" open>
                    <summary><h2>Typography</h2></summary>
                    <div class="panel--padded__body">

                    <div class="example-group">
                        <div class="example-label">h1</div>
                        <h1>Heading 1 - Main Page Title</h1>
                    </div>

                    <div class="example-group">
                        <div class="example-label">h2</div>
                        <h2>Heading 2 - Section Title</h2>
                    </div>

                    <div class="example-group">
                        <div class="example-label">h3</div>
                        <h3>Heading 3 - Subsection Title</h3>
                    </div>

                    <div class="example-group">
                        <div class="example-label">h4</div>
                        <h4>Heading 4 - Component Title</h4>
                    </div>

                    <div class="example-group">
                        <div class="example-label">h5</div>
                        <h5>Heading 5 - Small Title</h5>
                    </div>

                    <div class="example-group">
                        <div class="example-label">h6</div>
                        <h6>Heading 6 - Micro Title</h6>
                    </div>

                    <div class="example-group">
                        <div class="example-label">.subtitle</div>
                        <div class="subtitle">Subtitle text - 14px, uppercase, letter-spaced</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">.caption</div>
                        <div class="caption">Caption text - 12px, small supporting text</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">p (generic)</div>
                        <p>Regular paragraph text with the default body font, line height, and bottom spacing.</p>
                    </div>

                    <div class="example-group">
                        <div class="example-label">a (generic)</div>
                        <p><a href="#">A standard link</a> uses the primary color by default.</p>
                    </div>

                    </div>
                </details>

                <!-- Body Content -->
                <details class="panel panel--padded" id="body-content">
                    <summary><h2>Body Content</h2></summary>
                    <p>Content from Craft fields should render plain HTML and rely on generic element selectors.</p>
                    <div class="panel--padded__body">

                    <div class="example-group">
                        <div class="example-label">ul / ol (generic)</div>
                        <ul>
                            <li>Unordered list item</li>
                            <li>Another item with <a href="#">a link</a></li>
                        </ul>
                        <ol>
                            <li>Ordered list item</li>
                            <li>Another ordered item</li>
                        </ol>
                    </div>

                    <div class="example-group">
                        <div class="example-label">.list</div>
                        <p>A markerless list for navigation, tag clouds, and sidebar links.</p>
                        <ul class="list">
                            <li><a href="#">List item 1</a> <span class="caption">(5)</span></li>
                            <li><a href="#">List item 2</a> <span class="caption">(3)</span></li>
                            <li><a href="#">List item 3</a> <span class="caption">(12)</span></li>
                        </ul>
                    </div>

                    <div class="example-group">
                        <div class="example-label">blockquote (generic)</div>
                        <blockquote>
                            A blockquote pulls out quoted content with a left border and light background.
                        </blockquote>
                    </div>

                    <div class="example-group">
                        <div class="example-label">pre / code (generic)</div>
                        <p>Inline code looks like <code>this</code>.</p>
                        <pre><code>// A preformatted code block
function example() {
    return true;
}</code></pre>
                    </div>

                    <div class="example-group">
                        <div class="example-label">table (generic)</div>
                        <table>
                            <thead>
                                <tr><th>Heading</th><th>Heading</th></tr>
                            </thead>
                            <tbody>
                                <tr><td>Cell content</td><td>Cell content</td></tr>
                                <tr><td>Cell content</td><td>Cell content</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="example-group">
                        <div class="example-label">.body</div>
                        <div class="body">
                            <p>The <code>.body</code> class sets the container font size and line height. Generic child elements like paragraphs, lists, and tables pick up their own spacing from the global element selectors.</p>
                            <ul>
                                <li>Item one</li>
                                <li>Item two</li>
                            </ul>
                        </div>
                    </div>

                    </div>
                </details>

                <!-- Layout -->
                <details class="panel panel--padded" id="layout">
                    <summary><h2>Layout</h2></summary>
                    <div class="panel--padded__body">

                    <div class="example-group">
                        <div class="example-label">.shell</div>
                        <div class="shell" style="background: var(--secondary-light); padding: 16px; border: 1px solid var(--border);">
                            Container - 80% width, centered
                        </div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">.container</div>
                        <div class="container" style="position: static;">
                            <h3>Panel Title</h3>
                            <div class="container-content">Panel content with sticky positioning and light background.</div>
                            <div class="container-sections">
                                <div class="container-section">
                                    <h4>Panel Section</h4>
                                    <div class="container-content">Section content with border top.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">.container-section--headed</div>
                        <div class="container-section--headed">
                            <div class="container-section-header">Section Header</div>
                            <div class="container-section-body">A headed section with a grey header bar and content body. Use inside a panel or as a standalone group box.</div>
                        </div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">.panel.panel--padded</div>
                        <p>Panels live inside containers on this site. Consecutive panels inside a container get a 28px gap automatically.</p>
                        <div class="panel panel--padded">
                            <h3>Padded panel</h3>
                            <p>A panel with 24px padding, used for grouped content inside a container.</p>
                        </div>
                        <div class="panel panel--padded">
                            <h3>Second padded panel</h3>
                            <p>Consecutive panels inside a container get a 28px gap between them automatically.</p>
                        </div>
                    </div>

                    </div>
                </details>

                <!-- Cards & Images -->
                <details class="panel panel--padded" id="panels-images">
                    <summary><h2>Panels & Images</h2></summary>
                    <div class="panel--padded__body">

                    <div class="example-group">
                        <div class="example-label">.panel.panel--image-top</div>
                        <div class="panel panel--image-top">
                            <img class="thumb" src="https://picsum.photos/600/300" alt="Image top example">
                            <div class="panel-body">
                                <h3>Image-top panel</h3>
                                <p>The <code>--image-top</code> modifier removes panel padding so the image bleeds to the edges. The <code>.panel-body</code> wrapper re-adds padding around the text content below the image.</p>
                            </div>
                        </div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">.thumb</div>
                        <img class="thumb" src="https://picsum.photos/400/300" alt="Thumb image example">
                    </div>

                    <div class="example-group">
                        <div class="example-label">.gallery</div>
                        <div class="gallery">
                            <img class="gallery-image" src="https://picsum.photos/200/150" alt="Gallery image 1">
                            <img class="gallery-image" src="https://picsum.photos/200/150" alt="Gallery image 2">
                            <img class="gallery-image" src="https://picsum.photos/200/150" alt="Gallery image 3">
                            <img class="gallery-image" src="https://picsum.photos/200/150" alt="Gallery image 4">
                        </div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">.grid</div>
                        <div class="grid">
                            <article class="panel panel--image-top">
                                <img class="thumb" src="https://picsum.photos/200/150" alt="Card thumbnail">
                                <div class="panel-body">
                                    <div class="panel-chips">
                                        <span class="chip color-pair-gold">Project Type</span>
                                        <span class="chip color-pair-ink">Design Source</span>
                                    </div>
                                    <div class="panel-heading">
                                        <h3><a href="#">Card Title</a></h3>
                                        <div class="panel-category-chips">
                                            <span class="chip color-pair-sage">Category</span>
                                        </div>
                                    </div>
                                    <div class="panel-excerpt">A short excerpt that shows the panel body text truncation and line clamp behaviour.</div>
                                    <div class="caption">June 2026</div>
                                </div>
                            </article>
                            <article class="panel panel--image-top">
                                <img class="thumb" src="https://picsum.photos/200/150" alt="Card thumbnail">
                                <div class="panel-body">
                                    <div class="panel-chips">
                                        <span class="chip color-pair-sky">Another Type</span>
                                    </div>
                                    <div class="panel-heading">
                                        <h3><a href="#">Second Card</a></h3>
                                    </div>
                                    <div class="panel-excerpt">Another excerpt to demonstrate how panels sit in the grid.</div>
                                    <div class="caption">May 2026</div>
                                </div>
                            </article>
                        </div>
                    </div>

                    </div>
                </details>

                <!-- Buttons -->
                <details class="panel panel--padded" id="buttons">
                    <summary><h2>Buttons</h2></summary>
                    <div class="panel--padded__body">

                    <div class="example-row">
                        <div class="example-group">
                            <div class="example-label">.button</div>
                            <button class="button">Default Button</button>
                        </div>

                        <div class="example-group">
                            <div class="example-label">.button-primary</div>
                            <button class="button button-primary">Primary Button</button>
                        </div>

                        <div class="example-group">
                            <div class="example-label">.button-secondary</div>
                            <button class="button button-secondary">Secondary Button</button>
                        </div>

                        <div class="example-group">
                            <div class="example-label">.button-sm</div>
                            <button class="button button-sm">Small Button</button>
                        </div>

                        <div class="example-group">
                            <div class="example-label">.button-primary.button-sm</div>
                            <button class="button button-primary button-sm">Small Primary</button>
                        </div>
                    </div>

                    </div>
                </details>

                <!-- Chips -->
                <details class="panel panel--padded" id="chips">
                    <summary><h2>Chips</h2></summary>
                    <div class="panel--padded__body">
                    {% set colourPairs = [
                        { class: 'color-pair-gold', label: 'Muted Khaki' },
                        { class: 'color-pair-sand', label: 'Muted Sand' },
                        { class: 'color-pair-sage', label: 'Muted Sage' },
                        { class: 'color-pair-olive', label: 'Muted Olive' },
                        { class: 'color-pair-sky', label: 'Muted Sky' },
                        { class: 'color-pair-stone', label: 'Muted Stone' },
                        { class: 'color-pair-rose', label: 'Muted Rose' },
                        { class: 'color-pair-clay', label: 'Muted Clay' },
                        { class: 'color-pair-plum', label: 'Muted Plum' },
                        { class: 'color-pair-ink', label: 'Muted Ink' },
                        { class: 'color-pair-moss', label: 'Muted Moss' },
                        { class: 'color-pair-lavender', label: 'Muted Lavender' },
                        { class: 'color-pair-peach', label: 'Muted Peach' },
                        { class: 'color-pair-slate', label: 'Muted Slate' },
                        { class: 'color-pair-rust', label: 'Muted Rust' },
                        { class: 'color-pair-berry', label: 'Muted Berry' }
                    ] %}

                    <div class="example-row">
                        {% for pair in colourPairs %}
                            <div class="example-group">
                                <div class="example-label">.{{ pair.class }}</div>
                                <div class="chip {{ pair.class }}">{{ pair.label }}</div>
                            </div>
                        {% endfor %}
                    </div>

                    </div>
                </details>

                <!-- Design Tokens -->
                <details class="panel panel--padded" id="design-tokens">
                    <summary><h2>Design Tokens</h2></summary>
                    <div class="panel--padded__body">

                    <h3>Color Variables</h3>

                    <div class="example-group">
                        <div class="example-label">--primary</div>
                        <div class="color-swatch" style="background: var(--primary);"></div>
                        <div class="color-info">Primary color for links and accents</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--primary-dark</div>
                        <div class="color-swatch" style="background: var(--primary-dark);"></div>
                        <div class="color-info">Dark variant of primary</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--secondary</div>
                        <div class="color-swatch" style="background: var(--secondary);"></div>
                        <div class="color-info">Secondary color</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--secondary-light</div>
                        <div class="color-swatch" style="background: var(--secondary-light);"></div>
                        <div class="color-info">Light background for panels</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--secondary-dark</div>
                        <div class="color-swatch" style="background: var(--secondary-dark);"></div>
                        <div class="color-info">Dark variant of secondary</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--tertiary</div>
                        <div class="color-swatch" style="background: var(--tertiary);"></div>
                        <div class="color-info">Tertiary background color</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--tertiary-dark</div>
                        <div class="color-swatch" style="background: var(--tertiary-dark);"></div>
                        <div class="color-info">Dark variant of tertiary</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--body</div>
                        <div class="color-swatch" style="background: var(--body);"></div>
                        <div class="color-info">Main body text color</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--body-dark</div>
                        <div class="color-swatch" style="background: var(--body-dark);"></div>
                        <div class="color-info">Dark body text</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--body-light</div>
                        <div class="color-swatch" style="background: var(--body-light);"></div>
                        <div class="color-info">Light body text</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--border</div>
                        <div class="color-swatch" style="background: var(--border);"></div>
                        <div class="color-info">Border color</div>
                    </div>

                    <h3>Typography Size Variables</h3>

                    <div class="example-group">
                        <div class="example-label">--type-h1</div>
                        <div style="font-size: var(--type-h1);">Heading 1 Size</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--type-h2</div>
                        <div style="font-size: var(--type-h2);">Heading 2 Size</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--type-h3</div>
                        <div style="font-size: var(--type-h3);">Heading 3 Size</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--type-h4</div>
                        <div style="font-size: var(--type-h4);">Heading 4 Size</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--type-h5</div>
                        <div style="font-size: var(--type-h5);">Heading 5 Size</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--type-h6</div>
                        <div style="font-size: var(--type-h6);">Heading 6 Size</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--type-subtitle</div>
                        <div style="font-size: var(--type-subtitle);">Subtitle Size</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--type-body</div>
                        <div style="font-size: var(--type-body);">Body Size</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--type-caption</div>
                        <div style="font-size: var(--type-caption);">Caption Size</div>
                    </div>

                    <div class="example-group">
                        <div class="example-label">--type-button</div>
                        <div style="font-size: var(--type-button);">Button Size</div>
                    </div>

                    </div>
                </details>

            </div>
        </div>

        <aside class="sidebar sidebar--sticky">
            <div class="container-sections">
                <div class="container-section--headed">
                    <div class="container-section-header">Contents</div>
                    <div class="container-section-body">
                        <ul class="list">
                            <li><a href="#typography">Typography</a></li>
                            <li><a href="#body-content">Body Content</a></li>
                            <li><a href="#layout">Layout</a></li>
                            <li><a href="#panels-images">Panels & Images</a></li>
                            <li><a href="#buttons">Buttons</a></li>
                            <li><a href="#chips">Chips</a></li>
                            <li><a href="#design-tokens">Design Tokens</a></li>
                        </ul>
                    </div>
                </div>
                <div class="container-section--headed">
                    <div class="container-section-header">About</div>
                    <div class="container-section-body">
                        <div class="body">This page documents the site's generic element styles and shared CSS classes. Prefer plain HTML elements over bespoke classes.</div>
                    </div>
                </div>
            </div>
        </aside>

    </div>
</main>
{% endblock %}
