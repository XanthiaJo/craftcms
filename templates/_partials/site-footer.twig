{# _partials/site-footer.twig #}
<footer class="site-footer">
  <div class="shell footer-row">
    <div class="footer-socials">
      <a href="#">Facebook</a>
      <a href="#">X</a>
      <a href="#">Instagram</a>
      <a href="#">Pinterest</a>
    </div>
    <div class="footer-version" id="footer-version"></div>
  </div>
</footer>
<script src="/js/buildInfo.js?v={{ now|date('Ymd') }}"></script>
<script>
  (function() {
    var el = document.getElementById('footer-version');
    if (el && window.BUILD_INFO) {
      el.textContent = 'v' + window.BUILD_INFO.version.replace(/^v/, '') + ' (' + window.BUILD_INFO.commit + ')';
    }
  })();
</script>
