{% set siteHeader = siteHeader is defined ? siteHeader : craft.app.globals.getSetByHandle('siteHeader') %}
{% set siteName = siteName is defined ? siteName : (siteHeader and siteHeader.siteName ? siteHeader.siteName : '') %}
{% set headerNav = siteHeader and siteHeader.siteNavigation ? siteHeader.siteNavigation.all() : [] %}
{% set currentPath = craft.app.request.pathInfo ? '/' ~ craft.app.request.pathInfo|trim('/') : '/' %}

<header class="site-header">
    <div class="container header-row">
        <h1 class="brand">{{ siteName }}</h1>
{% if headerNav|length %}
        <nav class="main-nav" aria-label="Main navigation">
            {% for item in headerNav %}
                {% set itemLabel = attribute(item, 'siteNavLabel') is defined ? item.siteNavLabel : '' %}
                {% set itemUrl = attribute(item, 'siteNavUrl') is defined ? item.siteNavUrl : '' %}
                {% set submenuItems = attribute(item, 'siteNavChildren') is defined and item.siteNavChildren ? item.siteNavChildren : [] %}
                {% set hasSubmenu = submenuItems|length %}
                {% set submenuActive = false %}
                {% for submenuItem in submenuItems %}
                    {% set submenuUrl = submenuItem.url ?? submenuItem.col2 ?? '' %}
                    {% if submenuUrl %}
                        {% set submenuPath = submenuUrl starts with 'http' ? '' : submenuUrl %}
                        {% if submenuPath == '/' ? currentPath == '/' : (submenuPath and (currentPath == submenuPath or currentPath starts with submenuPath ~ '/')) %}
                            {% set submenuActive = true %}
                        {% endif %}
                    {% endif %}
                {% endfor %}
                {% set isActive = itemUrl == '/' ? currentPath == '/' : (itemUrl and (currentPath == itemUrl or currentPath starts with itemUrl ~ '/')) or submenuActive %}
                <div class="main-nav-item{{ hasSubmenu ? ' has-submenu' : '' }}">
                    {% if itemUrl %}
                        <a href="{{ itemUrl }}" class="main-nav-link{{ isActive ? ' active' : '' }}">{{ itemLabel }}</a>
                    {% else %}
                        <span class="main-nav-link{{ isActive ? ' active' : '' }}">{{ itemLabel }}</span>
                    {% endif %}
                    {% if hasSubmenu %}
                        <div class="main-nav-submenu" aria-label="{{ itemLabel }} submenu">
                            {% for submenuItem in submenuItems %}
                                {% set submenuLabel = submenuItem.label ?? submenuItem.col1 ?? '' %}
                                {% set submenuUrl = submenuItem.url ?? submenuItem.col2 ?? '' %}
                                {% if submenuLabel and submenuUrl %}
                                    <a class="main-nav-submenu-link" href="{{ submenuUrl }}">{{ submenuLabel }}</a>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </nav>
        <div class="header-project-links" aria-label="Project links">
            <a class="button" href="https://github.com/XanthiaJo/craftcms" target="_blank" rel="noopener noreferrer" aria-label="Open the project on GitHub">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.86 8.37 6.84 9.73.5.09.66-.22.66-.49v-1.73c-2.78.62-3.37-1.16-3.37-1.16-.46-1.2-1.12-1.52-1.12-1.52-.91-.63.07-.62.07-.62 1.01.07 1.54 1.07 1.54 1.07.9 1.58 2.35 1.12 2.92.86.09-.66.35-1.12.64-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.04 1.03-2.76-.1-.26-.45-1.31.1-2.73 0 0 .84-.27 2.75 1.05a9.12 9.12 0 0 1 5 0C16.78 6.07 17.62 6.34 17.62 6.34c.55 1.42.2 2.47.1 2.73.64.72 1.03 1.64 1.03 2.76 0 3.94-2.35 4.81-4.58 5.06.36.32.69.95.69 1.92v2.84c0 .27.16.59.67.49A10.27 10.27 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"/>
                </svg>
                <span>GitHub</span>
            </a>
            <a class="button" href="https://gitlab.com/structured-chaos/craftcms" target="_blank" rel="noopener noreferrer" aria-label="Open the project on GitLab">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M12 21.5 4.1 15.8c-.3-.2-.4-.6-.3-1l1.9-5.8h12.6l1.9 5.8c.1.4 0 .8-.3 1L12 21.5z"/>
                    <path d="m12 21.5 2.8-8.5H9.2L12 21.5z"/>
                    <path d="M12 21.5 4.1 15.8l7.9-2.8 0 8.5z"/>
                    <path d="M12 21.5 19.9 15.8l-7.9-2.8 0 8.5z"/>
                    <path d="m9.2 13 2.8-8.7L14.8 13H9.2z"/>
                    <path d="M4.4 14.8 6.2 9l3 4.2-4.8 1.6z"/>
                    <path d="M19.6 14.8 17.8 9l-3 4.2 4.8 1.6z"/>
                </svg>
                <span>GitLab</span>
            </a>
        </div>
{% endif %}
    </div>
</header>
