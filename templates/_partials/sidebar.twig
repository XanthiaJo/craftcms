<aside class="panel panel--sticky" aria-label="{{ title|default('Sidebar') }}">
    {% if title %}
        <h2>{{ title }}</h2>
    {% endif %}

    {% if intro %}
        <div class="panel-content">{{ intro }}</div>
    {% endif %}

    {% if sections is defined and sections|length %}
        <div class="panel-sections">
            {% for section in sections %}
                <div class="panel-section">
                    {% if section.title %}
                        <h3>{{ section.title }}</h3>
                    {% endif %}
                    {% if section.html is defined and section.html %}
                        <div class="body panel-content">{{ section.html|raw }}</div>
                    {% elseif section.text %}
                        <div class="body panel-content">{{ section.text }}</div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</aside>
