<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    {% set siteHeader = craft.app.globals.getSetByHandle('siteHeader') %}
    {% set siteName = siteHeader and siteHeader.siteName ? siteHeader.siteName : '' %}
    {% set projectsArchivePage = craft.entries.section('projectsArchive').status(null).siteId(craft.app.sites.currentSite.id).one() %}
    {% set projectsArchiveHeading = projectsArchivePage and attribute(projectsArchivePage, 'projectsArchiveHeading') is defined and projectsArchivePage.projectsArchiveHeading ? projectsArchivePage.projectsArchiveHeading : '' %}
    {% set projectsArchiveMetaDescription = projectsArchivePage and attribute(projectsArchivePage, 'projectsArchiveMetaDescription') is defined and projectsArchivePage.projectsArchiveMetaDescription ? projectsArchivePage.projectsArchiveMetaDescription : '' %}
    {% set projectsArchiveSidebarIntro = projectsArchivePage and attribute(projectsArchivePage, 'projectsArchiveSidebarIntro') is defined and projectsArchivePage.projectsArchiveSidebarIntro ? projectsArchivePage.projectsArchiveSidebarIntro : '' %}
    <title>{{ projectsArchiveHeading }} - {{ siteName }}</title>
    <meta name="description" content="{{ projectsArchiveMetaDescription|e('html_attr') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Open+Sans:wght@400;600;700&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f7f4ef;
            --surface: #ffffff;
            --text: #333333;
            --heading: #111111;
            --accent: #ca9b52;
            --border: #e8e2d8;
            --content-max: 1140px;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            color: var(--text);
            background: var(--bg);
            font-family: "Open Sans", sans-serif;
            line-height: 1.6;
        }

        a { color: var(--accent); text-decoration: none; }
        a:hover { opacity: 0.85; }

        .container {
            width: min(var(--content-max), 100% - 48px);
            margin: 0 auto;
        }

        .site-header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .header-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 72px;
            gap: 24px;
        }

        .brand {
            margin: 0;
            color: var(--heading);
            font-family: "Dancing Script", cursive;
            font-size: clamp(30px, 4vw, 48px);
            line-height: 1;
            white-space: nowrap;
        }

        .main-nav {
            display: flex;
            gap: 26px;
            align-items: center;
        }

        .main-nav a {
            color: #222;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .main-nav a.active {
            color: var(--accent);
        }

        .page-title-wrap {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 42px 0;
            margin-bottom: 38px;
        }

        .page-title {
            margin: 0;
            font-family: "Playfair Display", serif;
            color: var(--heading);
            font-size: clamp(30px, 5vw, 44px);
            font-weight: 400;
            text-align: center;
            letter-spacing: 0.5px;
        }

        .projects {
            padding-bottom: 68px;
        }

        .content-with-sidebar {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 290px;
            gap: 28px;
            align-items: start;
        }

        .content-main {
            min-width: 0;
        }

        .side-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 22px;
            position: sticky;
            top: 96px;
        }

        .side-panel-title {
            margin: 0 0 12px;
            color: var(--heading);
            font-family: "Playfair Display", serif;
            font-size: 28px;
            font-weight: 400;
            line-height: 1.2;
        }

        .side-panel-intro {
            font-size: 14px;
            line-height: 1.7;
        }

        .side-panel-sections {
            margin-top: 18px;
            display: grid;
            gap: 14px;
        }

        .side-panel-section {
            padding-top: 12px;
            border-top: 1px solid var(--border);
        }

        .side-panel-section-title {
            margin: 0 0 8px;
            color: var(--heading);
            font-family: "Playfair Display", serif;
            font-size: 18px;
            font-weight: 400;
        }

        .side-panel-text {
            font-size: 14px;
            line-height: 1.7;
        }

        .taxonomy-list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            gap: 8px;
        }

        .taxonomy-option {
            display: flex;
            align-items: baseline;
            gap: 8px;
            color: var(--heading);
            font-size: 14px;
            line-height: 1.5;
        }

        .taxonomy-option input {
            margin: 0;
            accent-color: var(--accent);
        }

        .taxonomy-option-label {
            color: var(--heading);
        }

        .side-panel-actions {
            margin-top: 18px;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .side-panel-button,
        .side-panel-reset {
            display: inline-block;
            padding: 10px 14px;
            border-radius: 4px;
            border: 1px solid var(--border);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .side-panel-button {
            background: #333;
            color: #fff;
            cursor: pointer;
        }

        .side-panel-button:hover {
            background: var(--accent);
        }

        .side-panel-reset {
            background: transparent;
            color: var(--heading);
        }

        .taxonomy-list .count {
            color: #8a8a8a;
        }

        .grid {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            gap: 26px;
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 6px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .thumb {
            width: 100%;
            aspect-ratio: 4 / 3;
            object-fit: cover;
            display: block;
        }

        .card-content {
            padding: 18px 18px 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            flex: 1;
        }

        .card-categories {
            font-size: 12px;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 1px;
            line-height: 1.5;
        }

        .card-type-chip {
            display: inline-block;
            align-self: flex-start;
            padding: 5px 10px;
            border-radius: 999px;
            background: #f2eee8;
            color: var(--heading);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .card-type-chip--coding {
            background: #d9e7f2;
            color: #22415f;
        }

        .card-type-chip--needlework {
            background: #f7ddd8;
            color: #7a3325;
        }

        .card-type-chip--modeling {
            background: #e7e2f4;
            color: #4d3d75;
        }

        .card-design-source-chip {
            display: inline-block;
            align-self: flex-start;
            padding: 5px 10px;
            border-radius: 999px;
            background: #e8efe6;
            color: #2f5a3b;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .card-design-source-chip--original {
            background: #e8efe6;
            color: #2f5a3b;
        }

        .card-design-source-chip--pattern {
            background: #fff3e0;
            color: #c65100;
        }

        .card-design-source-chip--model {
            background: #dfeaf2;
            color: #24516d;
        }

        .card-design-source-chip--reference {
            background: #e3f2fd;
            color: #1565c0;
        }

        .card-categories a {
            color: var(--accent);
        }

        .card-title {
            margin: 0;
            font-family: "Playfair Display", serif;
            font-size: 25px;
            font-weight: 400;
            line-height: 1.3;
            color: var(--heading);
        }

        .meta {
            margin-top: auto;
            font-size: 12px;
            color: #8a8a8a;
            text-transform: uppercase;
            letter-spacing: 1.1px;
        }

        .site-footer {
            border-top: 1px solid var(--border);
            background: #f2eee8;
            padding: 22px 0;
        }

        .footer-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 14px;
            font-size: 13px;
        }

        .footer-socials {
            display: flex;
            gap: 14px;
        }

        .footer-socials a {
            color: #333;
            font-weight: 600;
        }

        @media (max-width: 980px) {
            .content-with-sidebar {
                grid-template-columns: 1fr;
            }

            .side-panel {
                position: static;
            }

            .grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 740px) {
            .container {
                width: min(var(--content-max), 100% - 28px);
            }

            .main-nav {
                gap: 14px;
            }

            .main-nav a {
                font-size: 12px;
                letter-spacing: 0.6px;
            }

            .grid {
                grid-template-columns: 1fr;
            }

            .footer-row {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>
{% include '_partials/site-header.twig' %}
{% set postsIndexUrl = '/posts' %}
{% set selectedCategorySlugs = craft.app.request.getQueryParam('category', []) %}
{% set selectedProjectTypeSlugs = craft.app.request.getQueryParam('projectType', []) %}
{% set selectedTagSlugs = craft.app.request.getQueryParam('tag', []) %}
{% set selectedYears = craft.app.request.getQueryParam('year', []) %}
{% if selectedCategorySlugs is not iterable %}
    {% set selectedCategorySlugs = selectedCategorySlugs ? [selectedCategorySlugs] : [] %}
{% endif %}
{% if selectedProjectTypeSlugs is not iterable %}
    {% set selectedProjectTypeSlugs = selectedProjectTypeSlugs ? [selectedProjectTypeSlugs] : [] %}
{% endif %}
{% if selectedTagSlugs is not iterable %}
    {% set selectedTagSlugs = selectedTagSlugs ? [selectedTagSlugs] : [] %}
{% endif %}
{% if selectedYears is not iterable %}
    {% set selectedYears = selectedYears ? [selectedYears] : [] %}
{% endif %}
{% set allPosts = craft.entries.section('posts').type('post').with(['featuredImage', 'designSource', 'projectTypes', 'postCategories', 'postTags']).orderBy('postDate desc').all() %}
{% set archiveProjectTypes = craft.app.categories.getGroupByHandle('projectTypes') ? craft.categories.group('projectTypes').orderBy('lft asc').all() : [] %}
{% set projectTypeExpandedSlugsBySlug = {} %}
{% for projectType in archiveProjectTypes %}
    {% set expandedSlugs = [projectType.slug] %}
    {% set projectTypeDescendants = craft.categories.group('projectTypes').descendantOf(projectType).orderBy('lft asc').all() %}
    {% for descendant in projectTypeDescendants %}
        {% set expandedSlugs = expandedSlugs|merge([descendant.slug]) %}
    {% endfor %}
    {% set projectTypeExpandedSlugsBySlug = projectTypeExpandedSlugsBySlug|merge({
        (projectType.slug): expandedSlugs
    }) %}
{% endfor %}
{% set selectedProjectTypeMatchSlugs = [] %}
{% for selectedProjectTypeSlug in selectedProjectTypeSlugs %}
    {% set selectedProjectTypeMatchSlugs = selectedProjectTypeMatchSlugs|merge(projectTypeExpandedSlugsBySlug[selectedProjectTypeSlug] ?? [selectedProjectTypeSlug]) %}
{% endfor %}
{% set entries = [] %}
{% set archiveYears = [] %}
{% set seenYears = [] %}
{% set postIdsByProjectTypeSlug = {} %}
{% for postEntry in allPosts %}
    {% set postYear = postEntry.postDate ? postEntry.postDate|date('Y') : null %}
    {% if postYear and postYear not in seenYears %}
        {% set seenYears = seenYears|merge([postYear]) %}
        {% set archiveYears = archiveYears|merge([postYear]) %}
    {% endif %}
    {% set rawEntryProjectTypes = attribute(postEntry, 'projectTypes') is defined and postEntry.projectTypes ? postEntry.projectTypes.all() : [] %}
    {% set entryProjectTypeSlugs = [] %}
    {% for projectType in rawEntryProjectTypes %}
        {% set entryProjectTypeSlugs = entryProjectTypeSlugs|merge([projectType.slug]) %}
    {% endfor %}
    {% if entryProjectTypeSlugs|length %}
        {% for projectTypeSlug in entryProjectTypeSlugs %}
            {% set projectTypeAncestors = projectTypeExpandedSlugsBySlug[projectTypeSlug] ?? [projectTypeSlug] %}
            {% for archiveProjectType in archiveProjectTypes %}
                {% set archiveProjectTypeExpandedSlugs = projectTypeExpandedSlugsBySlug[archiveProjectType.slug] ?? [archiveProjectType.slug] %}
                {% if projectTypeSlug in archiveProjectTypeExpandedSlugs %}
                    {% set existingPostIds = postIdsByProjectTypeSlug[archiveProjectType.slug] ?? [] %}
                    {% if postEntry.id not in existingPostIds %}
                        {% set postIdsByProjectTypeSlug = postIdsByProjectTypeSlug|merge({
                            (archiveProjectType.slug): existingPostIds|merge([postEntry.id])
                        }) %}
                    {% endif %}
                {% endif %}
            {% endfor %}
        {% endfor %}
    {% endif %}
    {% set rawEntryCategories = attribute(postEntry, 'postCategories') is defined and postEntry.postCategories ? postEntry.postCategories.all() : [] %}
    {% set entryCategories = [] %}
    {% set entryCategorySlugs = [] %}
    {% for category in rawEntryCategories %}
        {% if not (category.title matches '/^\\d{4}$/') %}
            {% set entryCategories = entryCategories|merge([category]) %}
            {% set entryCategorySlugs = entryCategorySlugs|merge([category.slug]) %}
        {% endif %}
    {% endfor %}
    {% set entryTags = attribute(postEntry, 'postTags') is defined and postEntry.postTags ? postEntry.postTags.all() : [] %}
    {% set entryTagSlugs = [] %}
    {% for tag in entryTags %}
        {% set entryTagSlugs = entryTagSlugs|merge([tag.slug]) %}
    {% endfor %}
    {% set categoryMatch = not selectedCategorySlugs|length %}
    {% for selectedCategorySlug in selectedCategorySlugs %}
        {% if selectedCategorySlug in entryCategorySlugs %}
            {% set categoryMatch = true %}
        {% endif %}
    {% endfor %}
    {% set tagMatch = not selectedTagSlugs|length %}
    {% for selectedTagSlug in selectedTagSlugs %}
        {% if selectedTagSlug in entryTagSlugs %}
            {% set tagMatch = true %}
        {% endif %}
    {% endfor %}
    {% set projectTypeMatch = not selectedProjectTypeSlugs|length %}
    {% for selectedProjectTypeMatchSlug in selectedProjectTypeMatchSlugs %}
        {% if selectedProjectTypeMatchSlug in entryProjectTypeSlugs %}
            {% set projectTypeMatch = true %}
        {% endif %}
    {% endfor %}
    {% set yearMatch = not selectedYears|length %}
    {% for selectedYear in selectedYears %}
        {% if selectedYear == postYear %}
            {% set yearMatch = true %}
        {% endif %}
    {% endfor %}
    {% if categoryMatch and projectTypeMatch and tagMatch and yearMatch %}
        {% set entries = entries|merge([postEntry]) %}
    {% endif %}
{% endfor %}
{% set hasActiveFilters = selectedCategorySlugs|length or selectedProjectTypeSlugs|length or selectedTagSlugs|length or selectedYears|length %}

<section class="page-title-wrap">
    <div class="container">
        <h2 class="page-title">{{ projectsArchiveHeading }}</h2>
    </div>
</section>

<main class="projects">
    <div class="container content-with-sidebar">
        <div class="content-main">
            <ul class="grid" aria-label="Completed project list">
                {% for entry in entries %}
                    {% set image = entry.featuredImage ? entry.featuredImage.one() : null %}
                    <li class="card">
                    {% if image %}
                        <a href="{{ entry.url }}" aria-label="View {{ entry.title }}">
                            <img class="thumb" src="{{ image.url }}" alt="{{ image.title ?: entry.title }}">
                        </a>
                    {% endif %}
                    <div class="card-content">
                        {% set rawEntryDesignSource = attribute(entry, 'designSource') is defined and entry.designSource ? entry.designSource.all() : [] %}
                        {% set entryDesignSource = rawEntryDesignSource[0] ?? null %}
                        {% if entryDesignSource %}
                            {% set designSourceSlug = entryDesignSource.slug ?? '' %}
                            {% set designSourceClass = 'card-design-source-chip' %}
                            {% if designSourceSlug in ['original', 'self-made', 'self-drafted'] %}
                                {% set designSourceClass = designSourceClass ~ ' card-design-source-chip--original' %}
                            {% elseif designSourceSlug in ['pattern', 'pattern-file', 'based-on-pattern', 'purchased-pattern'] %}
                                {% set designSourceClass = designSourceClass ~ ' card-design-source-chip--pattern' %}
                            {% elseif designSourceSlug in ['model', 'based-on-model', 'purchased-model'] %}
                                {% set designSourceClass = designSourceClass ~ ' card-design-source-chip--model' %}
                            {% elseif designSourceSlug in ['reference', 'referenced-remixed', 'remixed', 'adapted'] %}
                                {% set designSourceClass = designSourceClass ~ ' card-design-source-chip--reference' %}
                            {% endif %}
                            <div class="{{ designSourceClass }}">{{ entryDesignSource.title }}</div>
                        {% endif %}
                        {% set rawEntryProjectTypes = attribute(entry, 'projectTypes') is defined and entry.projectTypes ? entry.projectTypes.all() : [] %}
                        {% set entryProjectTypes = [] %}
                        {% for projectType in rawEntryProjectTypes %}
                            {% set entryProjectTypes = entryProjectTypes|merge([projectType]) %}
                        {% endfor %}
                        {% if entryProjectTypes|length %}
                            {% set entryProjectTypeChip = entryProjectTypes|first %}
                            {% for projectType in entryProjectTypes %}
                                {% if projectType.level > (entryProjectTypeChip.level ?? 0) %}
                                    {% set entryProjectTypeChip = projectType %}
                                {% endif %}
                            {% endfor %}
                            {% set entryProjectTypeRoot = entryProjectTypeChip %}
                            {% if entryProjectTypeChip.level > 1 %}
                                {% set entryProjectTypeRoot = entryProjectTypeChip.ancestor(1).one() ?? entryProjectTypeChip %}
                            {% endif %}
                            {% set entryProjectTypeChipClass = '' %}
                            {% if entryProjectTypeRoot %}
                                {% set entryProjectTypeChipClass = 'card-type-chip--' ~ entryProjectTypeRoot.slug %}
                            {% endif %}
                            <div class="card-type-chip {{ entryProjectTypeChipClass }}">{{ entryProjectTypeChip.title }}</div>
                        {% endif %}
                        {% set rawEntryCategories = attribute(entry, 'postCategories') is defined and entry.postCategories ? entry.postCategories.all() : [] %}
                        {% set entryCategories = [] %}
                        {% for category in rawEntryCategories %}
                            {% if not (category.title matches '/^\\d{4}$/') %}
                                {% set entryCategories = entryCategories|merge([category]) %}
                            {% endif %}
                        {% endfor %}
                        {% if entryCategories|length %}
                            <div class="card-categories">
                                {% for category in entryCategories %}
                                    <a href="{{ postsIndexUrl }}?category[]={{ category.slug|url_encode }}">{{ category.title }}</a>{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}
                        <h3 class="card-title"><a href="{{ entry.url }}">{{ entry.title }}</a></h3>
                        {% set excerpt = entry.body ? entry.body|striptags|trim : '' %}
                        {% if excerpt %}
                            <div>{{ excerpt|slice(0, 145) ~ (excerpt|length > 145 ? '...' : '') }}</div>
                        {% endif %}
                        <div class="meta">{{ entry.postDate|date('F Y') }}</div>
                    </div>
                    </li>
                {% else %}
                    <li class="card">
                        <div class="card-content">
                            <h3 class="card-title">No posts imported yet</h3>
                            <div>Run the WordPress import script to populate this page.</div>
                            <div class="meta">Awaiting content</div>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>

        {% set archiveCategories = craft.app.categories.getGroupByHandle('postCategories') ? craft.categories.group('postCategories').orderBy('title asc').all() : [] %}
        {% set topicalCategories = [] %}
        {% for category in archiveCategories %}
            {% if not (category.title matches '/^\\d{4}$/') %}
                {% set topicalCategories = topicalCategories|merge([category]) %}
            {% endif %}
        {% endfor %}
        {% set archiveTags = craft.app.tags.getTagGroupByHandle('postTags') ? craft.tags.group('postTags').orderBy('title asc').all() : [] %}
        <aside class="side-panel">
            <h2 class="side-panel-title">Browse by</h2>
            <div class="side-panel-intro">{{ projectsArchiveSidebarIntro }}</div>
            <form method="get" action="{{ postsIndexUrl }}">
                <div class="side-panel-sections">
                    <section class="side-panel-section">
                        <h3 class="side-panel-section-title">Project Type</h3>
                        {% if archiveProjectTypes|length %}
                            <ul class="taxonomy-list">
                                {% for projectType in archiveProjectTypes %}
                                    {% set projectTypeCount = (postIdsByProjectTypeSlug[projectType.slug] ?? [])|length %}
                                    <li>
                                        <label class="taxonomy-option">
                                            <input type="checkbox" name="projectType[]" value="{{ projectType.slug }}" {% if projectType.slug in selectedProjectTypeSlugs %}checked{% endif %}>
                                            <span class="taxonomy-option-label" style="padding-left: {{ ((projectType.level ?? 1) - 1) * 14 }}px">{{ projectType.title }}</span>
                                            <span class="count">({{ projectTypeCount }})</span>
                                        </label>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <div class="side-panel-text">No project types</div>
                        {% endif %}
                    </section>
                    <section class="side-panel-section">
                        <h3 class="side-panel-section-title">Categories</h3>
                        {% if topicalCategories|length %}
                            <ul class="taxonomy-list">
                                {% for category in topicalCategories %}
                                    {% set categoryCount = craft.entries.section('posts').type('post').relatedTo(category).count() %}
                                    <li>
                                        <label class="taxonomy-option">
                                            <input type="checkbox" name="category[]" value="{{ category.slug }}" {% if category.slug in selectedCategorySlugs %}checked{% endif %}>
                                            <span class="taxonomy-option-label">{{ category.title }}</span>
                                            <span class="count">({{ categoryCount }})</span>
                                        </label>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <div class="side-panel-text">No categories</div>
                        {% endif %}
                    </section>
                    <section class="side-panel-section">
                        <h3 class="side-panel-section-title">Tags</h3>
                        {% if archiveTags|length %}
                            <ul class="taxonomy-list">
                                {% for tag in archiveTags %}
                                    {% set tagCount = craft.entries.section('posts').type('post').relatedTo(tag).count() %}
                                    <li>
                                        <label class="taxonomy-option">
                                            <input type="checkbox" name="tag[]" value="{{ tag.slug }}" {% if tag.slug in selectedTagSlugs %}checked{% endif %}>
                                            <span class="taxonomy-option-label">{{ tag.title }}</span>
                                            <span class="count">({{ tagCount }})</span>
                                        </label>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <div class="side-panel-text">No tags</div>
                        {% endif %}
                    </section>
                    <section class="side-panel-section">
                        <h3 class="side-panel-section-title">Year</h3>
                        {% if archiveYears|length %}
                            <ul class="taxonomy-list">
                                {% for archiveYear in archiveYears %}
                                    {% set nextArchiveYear = archiveYear + 1 %}
                                    {% set yearCount = craft.entries.section('posts').type('post').postDate(['and', '>= ' ~ archiveYear ~ '-01-01', '< ' ~ nextArchiveYear ~ '-01-01']).count() %}
                                    <li>
                                        <label class="taxonomy-option">
                                            <input type="checkbox" name="year[]" value="{{ archiveYear }}" {% if archiveYear in selectedYears %}checked{% endif %}>
                                            <span class="taxonomy-option-label">{{ archiveYear }}</span>
                                            <span class="count">({{ yearCount }})</span>
                                        </label>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <div class="side-panel-text">No years</div>
                        {% endif %}
                    </section>
                </div>
                <div class="side-panel-actions">
                    <button class="side-panel-button" type="submit">Apply filters</button>
                    {% if hasActiveFilters %}
                        <a class="side-panel-reset" href="{{ postsIndexUrl }}">Clear filters</a>
                    {% endif %}
                </div>
            </form>
        </aside>
    </div>
</main>

<footer class="site-footer">
    <div class="container footer-row">
        <div class="footer-socials">
            <a href="#">Facebook</a>
            <a href="#">X</a>
