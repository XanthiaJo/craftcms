<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    {% set siteHeader = craft.app.globals.getSetByHandle('siteHeader') %}
    {% set siteName = siteHeader and siteHeader.siteName ? siteHeader.siteName : '' %}
    <title>{{ entry.title }} - {{ siteName }}</title>
    <meta name="description" content="Markdown content pulled from GitHub for {{ entry.title }}.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Open+Sans:wght@400;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/site.css">
</head>
<body>
{% include '_partials/site-header.twig' %}
{% set markdownSource = entry.markdownSourceUrl ? githubMarkdownSource(entry.markdownSourceUrl) : '' %}
{% include '_partials/page-subheader.twig' with {
    pageName: entry.title
} %}

<main class="page-main">
    <div class="container page-layout">
        <div class="panel">
        {% if markdownSource %}
            <div class="body">
                {{ markdownSource|markdown('gfm')|purify }}
            </div>
        {% else %}
            <h1>Markdown source unavailable</h1>
            <p class="body">Add a GitHub raw markdown URL in the entry editor to render this page.</p>
        {% endif %}
        </div>

        <aside class="panel panel--sticky">
            <h2>Source</h2>
            <div class="panel-content">This entry renders markdown directly from GitHub.</div>
            <div class="panel-sections">
                <section class="panel-section">
                    <h3>Content URL</h3>
                    {% if entry.markdownSourceUrl %}
                        <div class="body panel-content">
                            <a class="source-link" href="{{ entry.markdownSourceUrl }}" target="_blank" rel="noopener noreferrer">{{ entry.markdownSourceUrl }}</a>
                        </div>
                    {% else %}
                        <div class="body panel-content">No source URL set.</div>
                    {% endif %}
                </section>
            </div>
        </aside>
    </div>
</main>

{% include '_partials/site-footer.twig' %}

</body>
</html>
