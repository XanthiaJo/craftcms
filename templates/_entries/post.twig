{% extends '_layouts/base.twig' %}

{% block pageTitle %}
    {{ entry.title }} - {{ parent() }}
{% endblock %}

{% block pageSubheader %}
    {% include '_partials/page-subheader.twig' with { pageName: entry.title } %}
{% endblock %}

{% block pageContent %}
{% set postsIndexUrl = '/posts' %}

{% set featuredImage = entry.featuredImage ? entry.featuredImage.one() : null %}
{% set rawEntryProjectTypes = attribute(entry, 'projectTypes') is defined and entry.projectTypes ? entry.projectTypes.all() : [] %}
{% set entryProjectTypes = [] %}
{% for projectType in rawEntryProjectTypes %}
    {% set entryProjectTypes = entryProjectTypes|merge([projectType]) %}
{% endfor %}
{% set rawEntryDesignSource = attribute(entry, 'designSource') is defined and entry.designSource ? entry.designSource.all() : [] %}
{% set entryDesignSource = rawEntryDesignSource[0] ?? null %}
{% set rawEntryCategories = attribute(entry, 'postCategories') is defined and entry.postCategories ? entry.postCategories.all() : [] %}
{% set entryCategories = [] %}
{% for category in rawEntryCategories %}
    {% if not (category.title matches '/^\\d{4}$/') %}
        {% set entryCategories = entryCategories|merge([category]) %}
    {% endif %}
{% endfor %}
{% set entryTags = attribute(entry, 'postTags') is defined and entry.postTags ? entry.postTags.all() : [] %}
{% set instructionSections = attribute(entry, 'instructions') is defined and entry.instructions ? entry.instructions.all() : [] %}
{% set galleryImages = attribute(entry, 'postImages') is defined and entry.postImages ? entry.postImages.all() : [] %}
{% set allGalleryImages = [] %}
{% if featuredImage %}
    {% set allGalleryImages = allGalleryImages|merge([featuredImage]) %}
{% endif %}
{% if galleryImages|length %}
    {% set allGalleryImages = allGalleryImages|merge(galleryImages) %}
{% endif %}

<main class="page-main">
    <div class="shell page-layout">
        <div class="container">

            {# ===== Top card: featured image (bleeds to edges) + header + body + gallery ===== #}
            <div class="panel panel--image-top">
                {% if featuredImage %}
                    <img class="thumb" src="{{ featuredImage.url }}" alt="{{ featuredImage.title ?: entry.title }}">
                {% endif %}
                <div class="panel-body">
                    <div class="container-sections">
                        <div class="container-section">
                            <h1>{{ entry.title }}</h1>
                            <p class="caption">{{ entry.postDate|date('F j, Y') }}</p>
                            {% if entryCategories|length %}
                                <div class="subtitle">
                                    {% for category in entryCategories %}
                                        <a href="{{ postsIndexUrl }}?category[]={{ category.slug|url_encode }}">{{ category.title }}</a>{% if not loop.last %}, {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}
                            {% if entryTags|length %}
                                <div class="subtitle">
                                    {% for tag in entryTags %}
                                        <a href="{{ postsIndexUrl }}?tag[]={{ tag.slug|url_encode }}">{{ tag.title }}</a>{% if not loop.last %}, {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="container-section">
                            <div class="body">
                                {% if entry.body %}
                                    {{ entry.body|nl2br }}
                                {% endif %}
                            </div>
                            {% if allGalleryImages|length %}
                                <div class="gallery" aria-label="Post image gallery">
                                    {% for galleryImage in allGalleryImages %}
                                        <img class="gallery-image" src="{{ galleryImage.url }}" alt="{{ galleryImage.title ?: entry.title }}" data-full="{{ galleryImage.url }}">
                                    {% endfor %}
                                </div>
                            {% endif %}
                            <a class="button" href="/posts">Back to Completed Projects</a>
                        </div>
                    </div>
                </div>
            </div>

            {# ===== Bottom card: instructions ===== #}
            {% if instructionSections|length %}
                <div class="panel panel--padded">
                    <section class="instructions" aria-label="Instructions">
                        <h2>Instructions</h2>
                        <div class="container-sections">
                            {% for section in instructionSections %}
                                <div class="container-section">
                                    {% if section.instructionSectionHeading %}
                                        <h3>{{ section.instructionSectionHeading }}</h3>
                                    {% endif %}
                                    {% if section.instructionSectionSubheading %}
                                        <p class="subtitle">{{ section.instructionSectionSubheading }}</p>
                                    {% endif %}
                                    {% if section.instructionSectionText %}
                                        <div class="body">{{ section.instructionSectionText|nl2br }}</div>
                                    {% endif %}
                                    {% set sectionSteps = section.instructionSteps ? section.instructionSteps.all() : [] %}
                                    {% if sectionSteps|length %}
                                        <ol>
                                            {% for step in sectionSteps %}
                                                <li>
                                                    {% if step.instructionStepHeading %}
                                                        <h4>{{ step.instructionStepHeading }}</h4>
                                                    {% endif %}
                                                    {% set textBlocks = step.instructionStepTexts ? step.instructionStepTexts.all() : [] %}
                                                    {% if textBlocks|length %}
                                                        <ol>
                                                            {% for textBlock in textBlocks %}
                                                                <li>
                                                                    {{ textBlock.instructionStepTextLine|nl2br }}
                                                                    {% set blockImages = textBlock.instructionStepTextImage ? textBlock.instructionStepTextImage.all() : [] %}
                                                                    {% if blockImages|length %}
                                                                        <div class="gallery">
                                                                            {% for blockImage in blockImages %}
                                                                                <img class="gallery-image" src="{{ blockImage.url }}" alt="{{ blockImage.title ?: textBlock.instructionStepTextLine ?: 'Instruction image' }}" data-full="{{ blockImage.url }}">
                                                                            {% endfor %}
                                                                        </div>
                                                                    {% endif %}
                                                                </li>
                                                            {% endfor %}
                                                        </ol>
                                                    {% endif %}
                                                </li>
                                            {% endfor %}
                                        </ol>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    </section>
                </div>
            {% endif %}

        </div>

        {% set categoriesSidebarHtml %}
            {% if entryCategories|length %}
                <ul class="list">
                    {% for category in entryCategories %}
                        <li class="cat-item"><a href="{{ postsIndexUrl }}?category[]={{ category.slug|url_encode }}">{{ category.title }}</a></li>
                    {% endfor %}
                </ul>
            {% else %}
                <ul class="list"><li class="cat-item-none">No categories</li></ul>
            {% endif %}
        {% endset %}
        {% set projectTypesSidebarHtml %}
            {% if entryProjectTypes|length %}
                <ul class="list">
                    {% for projectType in entryProjectTypes %}
                        <li class="cat-item"><a href="{{ postsIndexUrl }}?projectType[]={{ projectType.slug|url_encode }}">{{ projectType.title }}</a></li>
                    {% endfor %}
                </ul>
            {% else %}
                <ul class="list"><li class="cat-item-none">No project types</li></ul>
            {% endif %}
        {% endset %}
        {% set designSourceSidebarHtml %}
            {% if entryDesignSource %}
                <ul class="list">
                    <li class="cat-item"><a href="{{ postsIndexUrl }}?designSource[]={{ entryDesignSource.slug|url_encode }}">{{ entryDesignSource.title }}</a></li>
                </ul>
            {% else %}
                <ul class="list"><li class="cat-item-none">No design source</li></ul>
            {% endif %}
        {% endset %}
        {% set tagsSidebarHtml %}
            {% if entryTags|length %}
                <ul class="list">
                    {% for tag in entryTags %}
                        <li class="cat-item"><a href="{{ postsIndexUrl }}?tag[]={{ tag.slug|url_encode }}">{{ tag.title }}</a></li>
                    {% endfor %}
                </ul>
            {% else %}
                <ul class="list"><li class="cat-item-none">No tags</li></ul>
            {% endif %}
        {% endset %}
        {% set resourceLinksSidebarHtml %}
            {% if attribute(entry, 'resourceLinks') is defined and entry.resourceLinks|length %}
                {% for row in entry.resourceLinks %}
                    {% set url = row.url ?? row.col2 ?? null %}
                    {% set label = row.label ?? row.col1 ?? '' %}
                    {% if url %}
                        <a class="button button-primary" href="{{ url }}" target="_blank" rel="noopener">{{ label }}</a>
                    {% endif %}
                {% endfor %}
            {% else %}
                <ul class="list"><li class="cat-item-none">No resource links</li></ul>
            {% endif %}
        {% endset %}

        {% include '_partials/sidebar.twig' with {
            sections: [
                { title: 'Design Source', html: designSourceSidebarHtml },
                { title: 'Project Type', html: projectTypesSidebarHtml },
                { title: 'Categories', html: categoriesSidebarHtml },
                { title: 'Tags', html: tagsSidebarHtml },
                { title: 'Year', text: entry.postDate|date('Y') },
                { title: 'Links', html: resourceLinksSidebarHtml }
            ]
        } only %}
    </div>
</main>
{% endblock %}