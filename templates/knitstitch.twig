{# knitstitch.twig - KnitStichGrid web app template (WPF-style layout) #}
<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  {% set siteHeader = craft.app.globals.getSetByHandle('siteHeader') %}
  {% set siteName = siteHeader and siteHeader.siteName ? siteHeader.siteName : '' %}
  <title>KnitStitch Grid - {{ siteName }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Open+Sans:wght@400;600;700&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/site.css">
</head>
<body class="page-knitstitch">
  {% include '_partials/site-header.twig' %}
  {% include '_partials/page-subheader.twig' with { pageName: 'KnitStitch Grid' } %}

  <div class="shell">
    <div id="app-container">

    {# Ribbon workspace bar #}
    <div class="ribbon-bar">
      <div class="ribbon-modes">
        <button class="workspace-btn active" onclick="setWorkspace('sketch', this)" data-workspace="sketch">
          <span class="icon">&#x270F;</span>
          <span class="label">Sketch</span>
        </button>
        <button class="workspace-btn" onclick="setWorkspace('overlay', this)" data-workspace="overlay">
          <span class="icon">&#x1F5BC;</span>
          <span class="label">Overlay</span>
        </button>
        <button class="workspace-btn" onclick="setWorkspace('templates', this)" data-workspace="templates">
          <span class="icon">&#x1F4D0;</span>
          <span class="label">Templates</span>
        </button>
        <button class="workspace-btn" onclick="setWorkspace('options', this)" data-workspace="options">
          <span class="icon">&#x2699;</span>
          <span class="label">Options</span>
        </button>
      </div>
    </div>

    {# Main workspace #}
    <div class="page-layout page-layout--wide">

      {# Left: Canvas area #}
      <div class="canvas-area">
        <div class="canvas-wrapper">
          <div class="canvas-content" id="konva-stage"></div>
        </div>
        {# Floating zoom control — top-left of canvas area #}
        <div class="zoom-control" id="zoom-control">
          <button class="zoom-btn" id="zoom-in" title="Zoom in">&#x2B;</button>
          <span class="zoom-level" id="zoom-level">100%</span>
          <button class="zoom-btn" id="zoom-out" title="Zoom out">&#x2212;</button>
          <div class="zoom-divider"></div>
          <button class="zoom-btn" id="zoom-fit" title="Fit to screen">&#x29C9;</button>
          <button class="zoom-btn" id="zoom-reset" title="Reset to 100%">&#x21BB;</button>
        </div>
      </div>

      {# Right: Sidebar — content swaps with workspace #}
      <div class="sidebar" id="sidebar">

        {# Options workspace sidebar (formerly Grid) #}
        <div class="workspace-panel" id="panel-options">
          <div class="container-section--headed">
            <div class="container-section-header">Gauge (per 4 inches)</div>
            <div class="container-section-body">
              <div class="form-row">
                <label>Stitches:</label>
                <input type="number" id="gauge-stitches" value="20">
              </div>
              <div class="form-row">
                <label>Rows:</label>
                <input type="number" id="gauge-rows" value="28">
              </div>
            </div>
          </div>

          <div class="container-section--headed">
            <div class="container-section-header">Grid</div>
            <div class="container-section-body">
              <div class="caption" style="margin-top:8px;" id="grid-info">
                <strong>No cells filled</strong> — click the grid or draw a closed shape
              </div>
              <div class="caption" id="cell-size-info">
                Cell size: 20px wide x 28px high
              </div>
              <div style="display:flex;gap:8px;margin-top:8px;">
                <button class="button button-sm" id="btn-clear-manual-cells" title="Remove manually filled cells that are not inside a sketch shape">Clear Manual</button>
              </div>
            </div>
          </div>

          <div class="container-section--headed">
            <div class="container-section-header">Finished Size</div>
            <div class="container-section-body">
              <p id="finished-width">Width: -- in</p>
              <p id="finished-height">Height: -- in</p>
              <button class="button button-primary" id="btn-recalculate" style="margin-top:8px;">Recalculate</button>
            </div>
          </div>
        </div>

        {# Sketch workspace sidebar #}
        <div class="workspace-panel active" id="panel-sketch">
          <div class="container-section--headed">
            <div class="container-section-header">Sketch</div>
            <div class="container-section-body">
              <div class="form-row">
                <label>Line colour:</label>
                <select id="sketch-color">
                  <option value="#8b5d1f" selected class="color-option"><span class="color-swatch" style="background:#8b5d1f;"></span> Gold</option>
                  <option value="#E63946" class="color-option"><span class="color-swatch" style="background:#E63946;"></span> Red</option>
                  <option value="#FF6B35" class="color-option"><span class="color-swatch" style="background:#FF6B35;"></span> Orange</option>
                  <option value="#F4C430" class="color-option"><span class="color-swatch" style="background:#F4C430;"></span> Yellow</option>
                  <option value="#2D9E4F" class="color-option"><span class="color-swatch" style="background:#2D9E4F;"></span> Green</option>
                  <option value="#0A8A8A" class="color-option"><span class="color-swatch" style="background:#0A8A8A;"></span> Teal</option>
                  <option value="#1D70B8" class="color-option"><span class="color-swatch" style="background:#1D70B8;"></span> Blue</option>
                  <option value="#6A3D9A" class="color-option"><span class="color-swatch" style="background:#6A3D9A;"></span> Purple</option>
                  <option value="#E75480" class="color-option"><span class="color-swatch" style="background:#E75480;"></span> Pink</option>
                  <option value="#1A1A1A" class="color-option"><span class="color-swatch" style="background:#1A1A1A;"></span> Black</option>
                  <option value="#555555" class="color-option"><span class="color-swatch" style="background:#555555;"></span> Dark grey</option>
                  <option value="#999999" class="color-option"><span class="color-swatch" style="background:#999999;"></span> Grey</option>
                  <option value="#F5F5F5" class="color-option"><span class="color-swatch" style="background:#F5F5F5;"></span> White</option>
                </select>
              </div>
              <div class="form-row" style="margin-top:8px;">
                <label>Thickness:</label>
                <div class="slider-row">
                  <input type="range" id="sketch-thickness" min="1" max="10" value="2">
                </div>
              </div>
              <div class="checkbox-row">
                <input type="checkbox" id="previewMatch" checked>
                <label for="previewMatch">Preview matches line colour</label>
              </div>
              <div style="display:flex;gap:8px;margin-top:8px;">
                <button class="button button-sm" id="sketch-undo">Undo</button>
                <button class="button button-sm" id="sketch-clear">Clear</button>
                <button class="button button-sm" id="sketch-delete">Delete</button>
              </div>
              <p class="caption">Click to place points, chain lines. Snap ring = existing point. Right-click or Esc to cancel.</p>
            </div>
          </div>

          <div class="container-section--headed">
            <div class="container-section-header">Draw</div>
            <div class="container-section-body">
              <p style="font-size:12px;font-weight:600;margin-bottom:6px;">Shape tools:</p>
              <div class="toggle-group">
                <button class="button button-sm" id="tool-select">Select</button>
                <button class="button button-sm" id="tool-fill">Fill</button>
                <button class="button button-sm" id="tool-anchor">Anchor</button>
                <button class="button button-sm" id="tool-line">Line</button>
                <button class="button button-sm" id="tool-construction-line">Construction</button>
                <button class="button button-sm" disabled>Circle</button>
                <button class="button button-sm" disabled>Rectangle</button>
                <button class="button button-sm" disabled>Triangle</button>
              </div>
              <p class="caption">Basic geometric shapes for sketching. (Coming soon)</p>
            </div>
          </div>

          <div class="container-section--headed">
            <div class="container-section-header">Constraints</div>
            <div class="container-section-body">
              <p style="font-size:12px;font-weight:600;margin-bottom:6px;">Apply constraint:</p>
              <div class="toggle-group">
                <button class="button button-sm" id="tool-dimension">Dimension</button>
                <button class="button button-sm" id="tool-hv">H/V</button>
                <button class="button button-sm" disabled>Coincident</button>
                <button class="button button-sm" disabled>Tangent</button>
                <button class="button button-sm" id="tool-equal">Equal</button>
                <button class="button button-sm" disabled>Parallel</button>
                <button class="button button-sm" id="tool-perpendicular">Perpendicular</button>
                <button class="button button-sm" id="tool-midpoint">Midpoint</button>
              </div>
              <p class="caption">Constraints enforce geometric relationships between sketch entities.</p>
              <div id="sketch-constraint-status" class="caption" style="margin-top:8px;color:#c0392b;"></div>
            </div>
          </div>

          <div class="container-section--headed">
            <div class="container-section-header">Objects</div>
            <div class="container-section-body">
              <ul class="object-list" id="sketch-object-list">
              </ul>
              <button class="button button-sm" id="sketch-copy-objects" style="margin-top:8px;">Copy objects</button>
            </div>
          </div>
        </div>

        {# Overlay workspace sidebar #}
        <div class="workspace-panel" id="panel-overlay">
          <div class="container-section--headed">
            <div class="container-section-header">Image Overlay</div>
            <div class="container-section-body">
              <div class="form-row">
                <input type="text" id="overlay-path" placeholder="No image selected" readonly style="flex:1;">
                <button class="button button-sm" id="overlay-browse">Browse</button>
                <button class="button button-sm" id="overlay-clear">Clear</button>
                <input type="file" id="overlay-file" accept="image/*" style="display:none;">
              </div>
              <div class="checkbox-row">
                <input type="checkbox" id="overlay-show">
                <label for="overlay-show">Show overlay</label>
              </div>
              <div class="slider-row" style="margin-top:6px;">
                <label style="min-width:auto;">Opacity</label>
                <input type="range" id="overlay-opacity" min="0" max="100" value="50">
              </div>
            </div>
          </div>
        </div>

        {# Templates workspace sidebar #}
        <div class="workspace-panel" id="panel-templates">
          <div class="container-section--headed">
            <div class="container-section-header">Templates</div>
            <div class="container-section-body">
              <p class="caption">Click a template to generate it onto the grid. Generated lines can be manipulated in the Sketch workspace.</p>
              <div class="toggle-group" id="template-list">
              </div>
            </div>
          </div>

          <div class="container-section--headed" id="template-measurements-panel" style="display:none;">
            <div class="container-section-header">Measurements</div>
            <div class="container-section-body">
              <div class="form-row">
                <label>Foot circumference (in):</label>
                <input type="number" id="measurement-foot-circ" value="8.5" min="1" step="0.1">
              </div>
              <div class="form-row">
                <label>Foot length (in):</label>
                <input type="number" id="measurement-foot-len" value="9.5" min="1" step="0.1">
              </div>
              <div class="form-row">
                <label>Leg height (in):</label>
                <input type="number" id="measurement-leg-height" value="5.5" min="0.5" step="0.1">
              </div>
              <div class="form-row">
                <label>Negative ease (%):</label>
                <input type="number" id="measurement-ease" value="10" min="0" max="25" step="1">
              </div>
              <div class="form-row">
                <label>Ribbing length (in):</label>
                <input type="number" id="measurement-rib" value="1.0" min="0" step="0.1">
              </div>

              <div class="info-text" style="margin-top:10px;">
                <strong>Derived counts</strong>
              </div>
              <ul class="measurement-derived" id="measurement-derived">
                <li>Width: <span id="derived-width">--</span> sts</li>
                <li>Ribbing: <span id="derived-rib">--</span> rows</li>
                <li>Back leg: <span id="derived-section-a">--</span> rows</li>
                <li>Heel: <span id="derived-notch">--</span> rows</li>
                <li>Sole: <span id="derived-section-b">--</span> rows</li>
                <li>Toe: <span id="derived-notch-2">--</span> rows</li>
                <li>Instep + front leg: <span id="derived-section-c">--</span> rows</li>
                <li>Ribbing: <span id="derived-rib-2">--</span> rows</li>
              </ul>
              <p class="caption" style="margin-top:6px;">Gauge: <span id="derived-gauge">--</span> sts / <span id="derived-gauge-rows">--</span> rows per 4 in (edit in Grid panel).</p>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>
  </div>

  <script>
    function setWorkspace(ws, btn) {
      document.querySelectorAll('.workspace-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.workspace-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('panel-' + ws).classList.add('active');
    }
  </script>
  <script type="module" src="/dist/main.js"></script>
  {% include '_partials/site-footer.twig' %}
</body>
</html>
