{# knitstitch.twig - KnitStichGrid web app template (WPF-style layout) #}
<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  {% set siteHeader = craft.app.globals.getSetByHandle('siteHeader') %}
  {% set siteName = siteHeader and siteHeader.siteName ? siteHeader.siteName : '' %}
  <title>KnitStitch Grid - {{ siteName }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Open+Sans:wght@400;600;700&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/site.css">
  <link rel="stylesheet" href="/dist/main.css">
</head>
<body>
  {% include '_partials/site-header.twig' %}
  {% include '_partials/page-subheader.twig' with { pageName: 'KnitStitch Grid' } %}

  <div class="container">
    <div id="app-container">

    {# Ribbon workspace bar #}
    <div class="ribbon-bar">
      <div class="ribbon-modes">
        <button class="workspace-btn active" onclick="setWorkspace('grid')" data-workspace="grid">
          <span class="icon">&#x25A6;</span>
          <span class="label">Grid</span>
        </button>
        <button class="workspace-btn" onclick="setWorkspace('sketch')" data-workspace="sketch">
          <span class="icon">&#x270F;</span>
          <span class="label">Sketch</span>
        </button>
        <button class="workspace-btn" onclick="setWorkspace('overlay')" data-workspace="overlay">
          <span class="icon">&#x1F5BC;</span>
          <span class="label">Overlay</span>
        </button>
      </div>
    </div>

    {# Main workspace #}
    <div class="workspace">

      {# Left: Canvas area #}
      <div class="canvas-area">
        <div class="canvas-wrapper">
          <div class="canvas-content" id="konva-stage"></div>
        </div>
      </div>

      {# Right: Sidebar — content swaps with workspace #}
      <div class="sidebar" id="sidebar">

        {# Grid workspace sidebar #}
        <div class="workspace-panel active" id="panel-grid">
          <div class="group-box">
            <div class="group-header">Gauge (per 4 inches)</div>
            <div class="group-body">
              <div class="form-row">
                <label>Stitches:</label>
                <input type="number" id="gauge-stitches" value="20">
              </div>
              <div class="form-row">
                <label>Rows:</label>
                <input type="number" id="gauge-rows" value="28">
              </div>
            </div>
          </div>

          <div class="group-box">
            <div class="group-header">Grid (Cells)</div>
            <div class="group-body">
              <div class="form-row">
                <label>Columns:</label>
                <input type="number" id="grid-cols" value="30">
              </div>
              <div class="form-row">
                <label>Rows:</label>
                <input type="number" id="grid-rows" value="30">
              </div>
              <div class="info-text" style="margin-top:8px;" id="grid-info">
                <strong>Grid: 30 x 30 cells</strong> (900 total cells)
              </div>
              <div class="info-text" id="cell-size-info">
                Cell size: 20px wide x 28px high
              </div>
            </div>
          </div>

          <div class="group-box">
            <div class="group-header">Finished Size</div>
            <div class="group-body">
              <p id="finished-width">Width: -- in</p>
              <p id="finished-height">Height: -- in</p>
              <button class="button button-primary" id="btn-recalculate" style="margin-top:8px;">Recalculate</button>
            </div>
          </div>
        </div>

        {# Sketch workspace sidebar #}
        <div class="workspace-panel" id="panel-sketch">
          <div class="group-box">
            <div class="group-header">Sketch</div>
            <div class="group-body">
              <div class="form-row">
                <label>Line colour:</label>
                <select id="sketch-color">
                  <option value="#E63946" class="color-option"><span class="color-swatch" style="background:#E63946;"></span> Red</option>
                  <option value="#FF6B35" class="color-option"><span class="color-swatch" style="background:#FF6B35;"></span> Orange</option>
                  <option value="#F4C430" class="color-option"><span class="color-swatch" style="background:#F4C430;"></span> Yellow</option>
                  <option value="#2D9E4F" class="color-option"><span class="color-swatch" style="background:#2D9E4F;"></span> Green</option>
                  <option value="#0A8A8A" class="color-option"><span class="color-swatch" style="background:#0A8A8A;"></span> Teal</option>
                  <option value="#1D70B8" class="color-option"><span class="color-swatch" style="background:#1D70B8;"></span> Blue</option>
                  <option value="#6A3D9A" class="color-option"><span class="color-swatch" style="background:#6A3D9A;"></span> Purple</option>
                  <option value="#E75480" class="color-option"><span class="color-swatch" style="background:#E75480;"></span> Pink</option>
                  <option value="#1A1A1A" class="color-option"><span class="color-swatch" style="background:#1A1A1A;"></span> Black</option>
                  <option value="#555555" class="color-option"><span class="color-swatch" style="background:#555555;"></span> Dark grey</option>
                  <option value="#999999" class="color-option"><span class="color-swatch" style="background:#999999;"></span> Grey</option>
                  <option value="#F5F5F5" class="color-option"><span class="color-swatch" style="background:#F5F5F5;"></span> White</option>
                </select>
              </div>
              <div class="form-row" style="margin-top:8px;">
                <label>Thickness:</label>
                <div class="slider-row">
                  <input type="range" id="sketch-thickness" min="1" max="10" value="2">
                </div>
              </div>
              <div class="checkbox-row">
                <input type="checkbox" id="previewMatch" checked>
                <label for="previewMatch">Preview matches line colour</label>
              </div>
              <div style="display:flex;gap:8px;margin-top:8px;">
                <button class="button button-sm" id="sketch-undo">Undo</button>
                <button class="button button-sm" id="sketch-clear">Clear</button>
                <button class="button button-sm" id="sketch-delete">Delete</button>
              </div>
              <p class="info-text">Click to place points, chain lines. Snap ring = existing point. Right-click or Esc to cancel.</p>
            </div>
          </div>

          <div class="group-box">
            <div class="group-header">Draw</div>
            <div class="group-body">
              <p style="font-size:12px;font-weight:600;margin-bottom:6px;">Shape tools:</p>
              <div class="toggle-group">
                <button class="toggle-btn" id="tool-line">Line</button>
                <button class="toggle-btn" disabled>Circle</button>
                <button class="toggle-btn" disabled>Rectangle</button>
                <button class="toggle-btn" disabled>Triangle</button>
              </div>
              <button class="toggle-btn" id="tool-select" style="display:none;">Select</button>
              <p class="hint-text">Basic geometric shapes for sketching. (Coming soon)</p>
            </div>
          </div>

          <div class="group-box">
            <div class="group-header">Constraints</div>
            <div class="group-body">
              <p style="font-size:12px;font-weight:600;margin-bottom:6px;">Apply constraint:</p>
              <div class="toggle-group">
                <button class="toggle-btn" id="tool-dimension">Dimension</button>
                <button class="toggle-btn" disabled>H/V</button>
                <button class="toggle-btn" disabled>Coincident</button>
                <button class="toggle-btn" disabled>Tangent</button>
                <button class="toggle-btn" disabled>Equal</button>
                <button class="toggle-btn" disabled>Parallel</button>
                <button class="toggle-btn" id="tool-perpendicular">Perpendicular</button>
                <button class="toggle-btn" id="tool-midpoint">Midpoint</button>
              </div>
              <p class="hint-text">Constraints enforce geometric relationships between sketch entities.</p>
            </div>
          </div>

          <div class="group-box">
            <div class="group-header">Objects</div>
            <div class="group-body">
              <ul class="object-list" id="sketch-object-list">
              </ul>
            </div>
          </div>
        </div>

        {# Overlay workspace sidebar #}
        <div class="workspace-panel" id="panel-overlay">
          <div class="group-box">
            <div class="group-header">Image Overlay</div>
            <div class="group-body">
              <div class="form-row">
                <input type="text" id="overlay-path" placeholder="No image selected" readonly style="flex:1;">
                <button class="button button-sm" id="overlay-browse">Browse</button>
                <button class="button button-sm" id="overlay-clear">Clear</button>
                <input type="file" id="overlay-file" accept="image/*" style="display:none;">
              </div>
              <div class="checkbox-row">
                <input type="checkbox" id="overlay-show">
                <label for="overlay-show">Show overlay</label>
              </div>
              <div class="slider-row" style="margin-top:6px;">
                <label style="min-width:auto;">Opacity</label>
                <input type="range" id="overlay-opacity" min="0" max="100" value="50">
              </div>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>
  </div>

  <script>
    function setWorkspace(ws) {
      document.querySelectorAll('.workspace-btn').forEach(btn => btn.classList.remove('active'));
      document.querySelectorAll('.workspace-panel').forEach(p => p.classList.remove('active'));
      event.currentTarget.classList.add('active');
      document.getElementById('panel-' + ws).classList.add('active');
    }
  </script>
  <script type="module" src="/dist/main.js"></script>
  {% include '_partials/site-footer.twig' %}
</body>
</html>
