<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    {% set siteHeader = craft.app.globals.getSetByHandle('siteHeader') %}
    {% set siteName = siteHeader and siteHeader.siteName ? siteHeader.siteName : '' %}
    <title>{{ tag.title }} - {{ siteName }}</title>
    <meta name="description" content="Posts tagged {{ tag.title }}.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Open+Sans:wght@400;600;700&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f7f4ef;
            --surface: #ffffff;
            --text: #333333;
            --heading: #111111;
            --accent: #ca9b52;
            --border: #e8e2d8;
            --content-max: 1140px;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            color: var(--text);
            background: var(--bg);
            font-family: "Open Sans", sans-serif;
            line-height: 1.6;
        }
        a { color: var(--accent); text-decoration: none; }
        .container {
            width: min(var(--content-max), 100% - 48px);
            margin: 0 auto;
        }
        .site-header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 10;
        }
        .header-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 72px;
            gap: 24px;
        }
        .brand {
            color: var(--heading);
            font-family: "Dancing Script", cursive;
            font-size: clamp(30px, 4vw, 48px);
            line-height: 1;
            margin: 0;
            white-space: nowrap;
        }
        .main-nav {
            display: flex;
            gap: 26px;
            align-items: center;
        }
        .main-nav a {
            color: #222;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .main-nav a.active { color: var(--accent); }
        .page-title-wrap {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 42px 0;
            margin-bottom: 38px;
        }
        .page-title {
            margin: 0;
            font-family: "Playfair Display", serif;
            color: var(--heading);
            font-size: clamp(30px, 5vw, 44px);
            font-weight: 400;
            text-align: center;
            letter-spacing: 0.5px;
        }
        .projects {
            padding-bottom: 68px;
        }
        .grid {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            gap: 26px;
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 6px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        .thumb {
            width: 100%;
            aspect-ratio: 4 / 3;
            object-fit: cover;
            display: block;
        }
        .card-content {
            padding: 18px 18px 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            flex: 1;
        }
        .card-title {
            margin: 0;
            font-family: "Playfair Display", serif;
            font-size: 25px;
            font-weight: 400;
            line-height: 1.3;
            color: var(--heading);
        }
        .site-footer {
            border-top: 1px solid var(--border);
            background: #f2eee8;
            padding: 22px 0;
        }
        .footer-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 14px;
            font-size: 13px;
        }
        .footer-socials {
            display: flex;
            gap: 14px;
        }
        .footer-socials a {
            color: #333;
            font-weight: 600;
        }
        @media (max-width: 980px) {
            .grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }
        @media (max-width: 740px) {
            .container {
                width: min(var(--content-max), 100% - 28px);
            }
            .main-nav {
                gap: 14px;
            }
            .main-nav a {
                font-size: 12px;
                letter-spacing: 0.6px;
            }
            .grid {
                grid-template-columns: 1fr;
            }
            .footer-row {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>
{% include '_partials/site-header.twig' %}

<section class="page-title-wrap">
    <div class="container">
        <h2 class="page-title">{{ tag.title }}</h2>
    </div>
</section>

<main class="projects">
    <div class="container">
        {% set entries = craft.entries.section('posts').type('post').relatedTo(tag).orderBy('postDate desc').all() %}
        <ul class="grid" aria-label="{{ tag.title }} posts">
            {% for entry in entries %}
                {% set image = entry.featuredImage ? entry.featuredImage.one() : null %}
                <li class="card">
                    {% if image %}
                        <img class="thumb" src="{{ image.url }}" alt="{{ image.title ?: entry.title }}">
                    {% endif %}
                    <div class="card-content">
                        <h3 class="card-title"><a href="{{ entry.url }}">{{ entry.title }}</a></h3>
                        {% if entry.body %}
                            <div>{{ entry.body|striptags|trim|slice(0, 145) ~ '...' }}</div>
                        {% endif %}
                    </div>
                </li>
            {% else %}
                <li class="card">
                    <div class="card-content">
                        <h3 class="card-title">No posts in this tag yet</h3>
                        <div>Check back after more posts are tagged.</div>
                    </div>
                </li>
            {% endfor %}
        </ul>
    </div>
</main>

{% include '_partials/site-footer.twig' %}
</body>
</html>
