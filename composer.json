{
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "adigital/cookie-consent-banner": "^3.1.1",
    "craftcms/cms": "^5.10.7",
    "vlucas/phpdotenv": "^5.4.0"
  },
  "require-dev": {
    "craftcms/generator": "^2.0.0",
    "yiisoft/yii2-shell": "^2.0.3"
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "yiisoft/yii2-composer": true
    },
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example.dev', '.env');\""
    ],
    "build-info": [
      "@php scripts/GenerateBuildInfo.php --root=. --output=templates/_generated/build-info.twig --format=twiginfo",
      "@php scripts/GenerateBuildInfo.php --root=. --output=templates/_generated/change-log.twig --format=twig"
    ],
    "build-changelog": "@php scripts/GenerateBuildInfo.php --root=. --output=templates/_generated/change-log.twig --format=twig",
    "post-install-cmd": [
      "@build-info"
    ]
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.craftcms.com",
      "canonical": false
    }
  ]
}
